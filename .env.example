# Backend
DATABASE_URL=sqlite:///./camwatcher.db
SNAPSHOT_DIR=../media/snapshots
MEDIAMTX_URL=http://localhost:8888
MEDIAMTX_API_URL=http://localhost:9997
MEDIAMTX_RTSP_URL=rtsp://localhost:8554
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-32
MOTION_THRESHOLD=5000
FRAME_SKIP=5

# AI enrichment (OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
AI_ENRICHMENT_ENABLED=true
AI_ENRICHMENT_CONCURRENCY=2

# Frontend (copy to frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_MEDIAMTX_URL=http://localhost:8888
